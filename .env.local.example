# ── Razorpay (backend payments) ──────────────────────────────────────────
# Create keys at https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_…) while developing, live keys (rzp_live_…) in prod.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Calendly (acceleration page booking embed) ───────────────────────────
# Full scheduling URL, e.g. https://calendly.com/sonali-badani/clarity-call
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/clarity-call

# ── Pabbly webhook (funnel lead forwarding from the Welcome page) ─────────
# Pabbly Connect "Webhook" trigger URL. Exposed to the browser (NEXT_PUBLIC_)
# because the Welcome page posts the unified lead payload to it client-side.
NEXT_PUBLIC_PABBLY_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/xxxxxxxx
